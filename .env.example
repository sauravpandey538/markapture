# OpenRouter — required for Global Talent assessment
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=openai/gpt-5.5

# Deep research — appends :online + web plugin for real source URLs (default: true)
OPENROUTER_DEEP_RESEARCH=true

# Optional — used as HTTP-Referer header for OpenRouter
NEXT_PUBLIC_SITE_URL=https://markapture.co.uk
